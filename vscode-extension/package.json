{
  "name": "hx",
  "displayName": "HX",
  "description": "VS Code integration for the HX coding agent — sidebar dashboard, @gsd chat participant, activity feed, conversation history, code lens, session forking, slash command completion, workflow controls, and 33 commands",
  "publisher": "FluxLabs",
  "version": "0.2.0",
  "icon": "logo.jpg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperlab/hx"
  },
  "homepage": "https://github.com/hyperlab/hx/blob/main/vscode-extension/README.md",
  "bugs": {
    "url": "https://github.com/hyperlab/hx/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "coding",
    "hx",
    "chat",
    "automation",
    "claude",
    "openai",
    "llm"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "extensionKind": ["workspace"],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hx.start",
        "title": "HX: Start Agent"
      },
      {
        "command": "hx.stop",
        "title": "HX: Stop Agent"
      },
      {
        "command": "hx.newSession",
        "title": "HX: New Session"
      },
      {
        "command": "hx.sendMessage",
        "title": "HX: Send Message"
      },
      {
        "command": "hx.cycleModel",
        "title": "HX: Cycle Model"
      },
      {
        "command": "hx.cycleThinking",
        "title": "HX: Cycle Thinking Level"
      },
      {
        "command": "hx.compact",
        "title": "HX: Compact Context"
      },
      {
        "command": "hx.abort",
        "title": "HX: Abort Current Operation"
      },
      {
        "command": "hx.exportHtml",
        "title": "HX: Export Conversation as HTML"
      },
      {
        "command": "hx.sessionStats",
        "title": "HX: Show Session Stats"
      },
      {
        "command": "hx.runBash",
        "title": "HX: Run Bash Command"
      },
      {
        "command": "hx.switchModel",
        "title": "HX: Switch Model"
      },
      {
        "command": "hx.setThinking",
        "title": "HX: Set Thinking Level"
      },
      {
        "command": "hx.steer",
        "title": "HX: Steer Agent"
      },
      {
        "command": "hx.listCommands",
        "title": "HX: List Available Commands"
      },
      {
        "command": "hx.toggleAutoRetry",
        "title": "HX: Toggle Auto-Retry"
      },
      {
        "command": "hx.abortRetry",
        "title": "HX: Abort Retry"
      },
      {
        "command": "hx.setSessionName",
        "title": "HX: Set Session Name"
      },
      {
        "command": "hx.copyLastResponse",
        "title": "HX: Copy Last Response"
      },
      {
        "command": "hx.switchSession",
        "title": "HX: Switch Session"
      },
      {
        "command": "hx.refreshSessions",
        "title": "HX: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "hx.clearFileDecorations",
        "title": "HX: Clear File Decorations"
      },
      {
        "command": "hx.showHistory",
        "title": "HX: Show Conversation History"
      },
      {
        "command": "hx.askAboutSymbol",
        "title": "HX: Ask About Symbol"
      },
      {
        "command": "hx.clearActivity",
        "title": "HX: Clear Activity Feed",
        "icon": "$(clear-all)"
      },
      {
        "command": "hx.forkSession",
        "title": "HX: Fork Session"
      },
      {
        "command": "hx.toggleSteeringMode",
        "title": "HX: Toggle Steering Mode"
      },
      {
        "command": "hx.toggleFollowUpMode",
        "title": "HX: Toggle Follow-Up Mode"
      },
      {
        "command": "hx.refactorSymbol",
        "title": "HX: Refactor Symbol"
      },
      {
        "command": "hx.findBugsSymbol",
        "title": "HX: Find Bugs in Symbol"
      },
      {
        "command": "hx.generateTestsSymbol",
        "title": "HX: Generate Tests for Symbol"
      }
    ],
    "keybindings": [
      {
        "command": "hx.newSession",
        "key": "ctrl+shift+g ctrl+shift+n",
        "mac": "cmd+shift+g cmd+shift+n"
      },
      {
        "command": "hx.cycleModel",
        "key": "ctrl+shift+g ctrl+shift+m",
        "mac": "cmd+shift+g cmd+shift+m"
      },
      {
        "command": "hx.cycleThinking",
        "key": "ctrl+shift+g ctrl+shift+t",
        "mac": "cmd+shift+g cmd+shift+t"
      },
      {
        "command": "hx.abort",
        "key": "ctrl+shift+g ctrl+shift+a",
        "mac": "cmd+shift+g cmd+shift+a"
      },
      {
        "command": "hx.steer",
        "key": "ctrl+shift+g ctrl+shift+i",
        "mac": "cmd+shift+g cmd+shift+i"
      },
      {
        "command": "hx.sendMessage",
        "key": "ctrl+shift+g ctrl+shift+p",
        "mac": "cmd+shift+g cmd+shift+p"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hx",
          "title": "HX",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "hx": [
        {
          "type": "webview",
          "id": "hx-sidebar",
          "name": "HX Agent"
        },
        {
          "id": "hx-sessions",
          "name": "Sessions"
        },
        {
          "id": "hx-activity",
          "name": "Activity"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "hx.refreshSessions",
          "when": "view == hx-sessions",
          "group": "navigation"
        },
        {
          "command": "hx.clearActivity",
          "when": "view == hx-activity",
          "group": "navigation"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "hx.agent",
        "name": "hx",
        "fullName": "HX Agent",
        "description": "HX coding agent",
        "isSticky": true
      }
    ],
    "configuration": {
      "title": "HX",
      "properties": {
        "hx.binaryPath": {
          "type": "string",
          "default": "hx",
          "description": "Path to the HX binary"
        },
        "hx.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the HX agent when the extension activates"
        },
        "hx.autoCompaction": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic context compaction"
        },
        "hx.codeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show 'Ask HX' code lens above functions and classes"
        },
        "hx.showProgressNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show progress notification while the agent is working"
        },
        "hx.activityFeedMaxItems": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 500,
          "description": "Maximum number of items shown in the Activity feed"
        },
        "hx.showContextWarning": {
          "type": "boolean",
          "default": true,
          "description": "Warn when context window usage exceeds the threshold"
        },
        "hx.contextWarningThreshold": {
          "type": "number",
          "default": 80,
          "minimum": 50,
          "maximum": 95,
          "description": "Context window usage percentage that triggers a warning"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.7.0"
  }
}
