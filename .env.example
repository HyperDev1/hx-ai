# ─── HX Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# Only the variables you use need to be set — all are optional.

# ─── AI Provider API Keys ────────────────────────────────────────────────
# At least one provider key is needed for the agent to function.

# ANTHROPIC_API_KEY=sk-ant-...          # Anthropic Claude API
# OPENAI_API_KEY=sk-...                 # OpenAI (GPT models)
# GEMINI_API_KEY=...                    # Google Gemini
# GROQ_API_KEY=gsk_...                  # Groq (voice transcription)
# OLLAMA_API_KEY=...                    # Ollama (local models)
# CUSTOM_OPENAI_API_KEY=...             # Custom OpenAI-compatible endpoint

# ─── Search & Web ────────────────────────────────────────────────────────
# Keys for web search and page fetching tools.

# BRAVE_API_KEY=BSA...                  # Brave Search API (primary search)
# BRAVE_ANSWERS_KEY=BSA...              # Brave Answers API
# TAVILY_API_KEY=tvly-...               # Tavily Search (alternative)
# JINA_API_KEY=jina_...                 # Jina Reader (page fetching)
# CONTEXT7_API_KEY=...                  # Context7 (library docs)
# PREFER_BRAVE_SEARCH=true              # Prefer Brave over Tavily

# ─── Integrations ────────────────────────────────────────────────────────
# Tokens for external service integrations.

# GITHUB_TOKEN=ghp_...                  # GitHub API (issues, PRs, repos)
# DISCORD_BOT_TOKEN=...                 # Discord remote questions
# SLACK_BOT_TOKEN=xoxb-...             # Slack remote questions
# TELEGRAM_BOT_TOKEN=...               # Telegram remote questions

# ─── Vertex AI (Google Cloud) ────────────────────────────────────────────
# ANTHROPIC_VERTEX_PROJECT_ID=...       # GCP project ID for Vertex

# ─── HX Internal ─────────────────────────────────────────────────────────
# Usually set automatically by the CLI. Override only if needed.

# HX_ENV=production                     # Runtime environment (production|staging|local)
# HX_HOME=~/.hx                        # HX config/state directory
# HX_DEBUG=1                            # Enable debug logging
# HX_SHOW_TOKEN_COST=1                  # Show token cost in output
# HX_ENGINE_BYPASS=1                    # Bypass native engine
# HX_RTK_DISABLED=1                     # Disable RTK rewrites
# HX_STARTUP_TIMING=1                   # Show startup timing

# ─── Browser / Screenshots ───────────────────────────────────────────────
# BROWSER_PATH=/usr/bin/chromium        # Custom browser binary path
# FORCE_HEADLESS=1                      # Force headless browser mode
# SCREENSHOT_FORMAT=jpeg                # Screenshot format (jpeg|png)
# SCREENSHOT_QUALITY=80                 # JPEG quality (1-100)
# SCREENSHOT_MAX_WIDTH=1280             # Max screenshot width
# SCREENSHOT_MAX_HEIGHT=720             # Max screenshot height

# ─── Network ─────────────────────────────────────────────────────────────
# HTTP_PROXY=http://proxy:8080
# HTTPS_PROXY=http://proxy:8080
# PI_OFFLINE=1                          # Offline mode (no network calls)
