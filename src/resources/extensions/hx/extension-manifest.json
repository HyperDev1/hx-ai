{
  "id": "hx",
  "name": "HX Workflow",
  "version": "1.0.0",
  "description": "Core HX workflow engine — milestone planning, execution, and tracking",
  "tier": "core",
  "requires": { "platform": ">=2.29.0" },
  "provides": {
    "tools": [
      "bash", "write", "read", "edit",
      "hx_decision_save", "hx_summary_save",
      "hx_requirement_update", "hx_milestone_generate_id"
    ],
    "commands": ["hx", "kill", "worktree", "exit"],
    "hooks": ["session_start", "session_switch", "bash_transform", "session_fork", "before_agent_start", "agent_end", "session_before_compact", "session_shutdown", "tool_call", "tool_result", "tool_execution_start", "tool_execution_end", "model_select", "before_provider_request", "turn_end"],
    "shortcuts": ["Ctrl+Alt+G"]
  }
}
